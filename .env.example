# ============================================================
# WhatsApp Cloud API (Meta Graph API) – fuer WhatsApp Bot
# ============================================================
WHATSAPP_ENABLED=true

# Phone Number ID: Meta Developer Console → WhatsApp → API Setup → Phone Number ID
WHATSAPP_PHONE_NUMBER_ID=1042982108897017

# Permanent System User Token (nie ablaufend) oder temporaerer User Token (24h)
# Meta Business Suite → Einstellungen → System Users → Token generieren
# Benoetigt: whatsapp_business_management + whatsapp_business_messaging
WHATSAPP_API_TOKEN=EAAUeHXitCvsB...

# Selbst gewaehltes geheimes Wort fuer Webhook-Verifizierung
WHATSAPP_VERIFY_TOKEN=my_custom_verify_token_123

WHATSAPP_API_VERSION=v22.0

# Name des genehmigten Meta-Templates (nach Einreichung via create_wa_template.py)
WHATSAPP_TEMPLATE_NAME=sellcruiting_fallback_de

# WhatsApp Business Account ID: Meta Developer Console → WhatsApp → API Setup → WABA ID
# Benoetigt fuer Template-Management (create_wa_template.py)
WHATSAPP_WABA_ID=

# App Secret fuer Signatur-Validierung eingehender Webhooks
# Meta Developer Console → App → Einstellungen → Grundlegendes → App-Geheimnis
WHATSAPP_APP_SECRET=

# ============================================================
# Bestehende Variablen (Referenz)
# ============================================================
# DATABASE_URL=postgresql://...
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# HIRINGS_API_URL=https://...
# HIRING_API_TOKEN=...
# ELEVENLABS_API_KEY=...
# WHATSAPP_SESSION_TIMEOUT_HOURS=24
